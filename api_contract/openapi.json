              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Anomalie"
          }
        },
        "type": "object",
        "required": [
          "uuid",
          "umap_x",
          "umap_y",
          "umap_z",
          "label",
          "category",
          "filename"
